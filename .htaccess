# ==========================================================================
# CLEAN URLS SERVER REWRITES & REDIRECTS (APACHE SERVER)
# ==========================================================================

RewriteEngine On
RewriteBase /

# 1. Redirect external requests ending in .html to clean URLs
# E.g., /about.html -> /about and /index.html -> /
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Resolve index specifically to root if requested
RewriteRule ^index$ / [R=301,L]

# 3. Internally map clean URLs to their corresponding .html files
# Verify it is not a directory and the .html file exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]
